# Required — Obsidian vault paths (dual-vault setup)
# Personal vault: local-only. Daily notes, Tasks, raw meeting notes.
OBSIDIAN_PERSONAL_VAULT_PATH=/path/to/your/personal/vault
# Claimable vault: team-shared via Obsidian Sync. Product, Business, Reference, Templates, Agents.
OBSIDIAN_CLAIMABLE_VAULT_PATH=/path/to/your/claimable/vault

# Legacy fallback — used for either vault if the dedicated var above is not set.
# Remove once the physical vault split is complete.
# OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# Optional (defaults shown)
USER_NAME=User
DAILY_NOTE_TEMPLATE=Templates/Daily Rundown.md
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
CHAT_PORT=4001
PORT=4000
